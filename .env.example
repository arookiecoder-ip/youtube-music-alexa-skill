YTDLP_COOKIES=/app/cookies.txt
# Address served by Caddy. Use a hostname in production for automatic HTTPS,
# or http://localhost for local HTTP testing.
SITE_ADDRESS=http://localhost
# Shared secret used only for Flask-to-Chromium-sidecar control requests.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
YT_BROWSER_CONTROL_TOKEN=<generate-a-random-64-character-hex-token>
# Optional: maximum time allowed to complete interactive Google sign-in.
YT_BROWSER_LOGIN_TIMEOUT=240
# Seconds to display connection success before the secure browser exits.
YT_BROWSER_SUCCESS_DISPLAY=12
# Must be the actual public hostname the Echo/Alexa Lambda will reach this
# server at (a sslip.io hostname, or your own domain). If you migrate to a
# custom domain later, update this AND DEFAULT_API_URL in lambda/api_key.py —
# a stale value here is a common cause of "search works, no audio plays".
PUBLIC_BASE_URL=https://<your-ip-with-dashes>.sslip.io
API_KEY=<same value as lambda/api_key.py>
AMAZON_DOMAIN=amazon.in
SECRET_KEY=<openssl rand -hex 32>
REMOTE_USER=<pick a username>
REMOTE_PASSWORD=<pick a strong password>
REMOTE_TOTP_SECRET=<base32 secret, optional 2FA>
# Optional: only needed if the Amazon login proxy is served from a separate
# hostname/Caddy site block. Defaults to PUBLIC_BASE_URL if unset.
ALEXA_PROXY_BASE_URL=<https://your-proxy-hostname>

# Optional: YT Music browser auth file path for personalized recommendations.
# See: web remote → profile menu → "Fix personalized YouTube data"
# YTMUSIC_AUTH_FILE=/app/ytmusic_auth.json
