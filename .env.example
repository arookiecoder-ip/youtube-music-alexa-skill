YTDLP_COOKIES=/app/cookies.txt
PUBLIC_BASE_URL=https://<your-ip-with-dashes>.sslip.io
API_KEY=<same value as lambda/api_key.py>
AMAZON_DOMAIN=amazon.in
SECRET_KEY=<openssl rand -hex 32>
REMOTE_USER=<pick a username>
REMOTE_PASSWORD=<pick a strong password>
REMOTE_TOTP_SECRET=<base32 secret, optional 2FA>
# Optional: only needed if the Amazon login proxy is served from a separate
# hostname/Caddy site block. Defaults to PUBLIC_BASE_URL if unset.
ALEXA_PROXY_BASE_URL=<https://your-proxy-hostname>
